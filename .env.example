# ─── Qdrant ───────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=your-key-here
QDRANT_COLLECTION=ragos

# ─── Embedding ────────────────────────────────────────────────────────────────
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBED_DEVICE=cpu          # set to "mps" on Apple Silicon
EMBED_BATCH_SIZE=64

# ─── Chunking ─────────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
CHUNK_STRATEGY=recursive  # recursive | sentence_window

# ─── Retrieval ────────────────────────────────────────────────────────────────
TOP_K_DENSE=20
TOP_K_SPARSE=20
TOP_K_RERANK=5
HYBRID_ALPHA=0.7          # weight on dense score; (1 - alpha) on sparse

# ─── Generation ───────────────────────────────────────────────────────────────
# Backend: openai | anthropic | squish
GENERATOR_BACKEND=openai
MAX_TOKENS=1024
TEMPERATURE=0.1

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Anthropic (uncomment to use)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-haiku-20240307

# Squish / Ollama (local, no key needed)
SQUISH_BASE_URL=http://localhost:11434/v1
SQUISH_MODEL=qwen3:8b

# ─── RAGAS Eval ───────────────────────────────────────────────────────────────
RAGAS_LLM=gpt-4o-mini
